    <string name="settings_hc_title">Health Connect Settings</string>
    <string name="settings_hc_desc">Sync your workout records (distance, route, heart rate, steps, calories) with other health apps. You can choose which data to sync in the following system settings.</string>
    <string name="settings_hc_button_manage">Manage Permissions</string>
    <string name="settings_hc_rationale_title">Health Connect Sync</string>
    <string name="settings_hc_rationale_text">Permissions are required to sync workout records (heart rate, distance, route, steps, calories) with Health Connect.\n\nThis allows you to see Iron data in other health management apps.</string>
    <string name="settings_hc_button_settings">To Settings</string>
    <string name="settings_hc_notice_title">Notice Regarding Sync</string>
    <string name="settings_hc_notice_1">Data is automatically written to Health Connect upon saving.</string>
    <string name="settings_hc_notice_2">Deleting history in Iron will also delete the corresponding data in Health Connect.</string>
    <string name="settings_hc_notice_3">Heart rate, steps, distance, and route information are synced.</string>
