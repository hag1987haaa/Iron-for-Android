    <string name="settings_touch_title">Music Control</string>
    <string name="settings_touch_desc">Double tap: Play/Pause\nSwipe: Volume (Up/Down), Skip (Left/Right)\n\n* This feature works when touch operation is enabled in your watch\'s PebbleOS settings. You can use this switch on your phone to temporarily block music commands from the watch.</string>
    <string name="settings_touch_note">Note: Only available on touch-compatible models (Pebble Time 2 / Round 2)</string>

